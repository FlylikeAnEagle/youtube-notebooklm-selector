{
  "manifest_version": 3,
  "name": "YouTube Channel Selector for NotebookLM",
  "version": "1.0.0",
  "description": "Select videos from any YouTube channel and push them as sources to NotebookLM.",
  "permissions": [
    "storage",
    "scripting",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://notebooklm.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "YouTube Channel Selector for NotebookLM"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
